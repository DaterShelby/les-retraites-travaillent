# =============================================================================
#  Les Retraités Travaillent — variables d'environnement
#  Copier en `.env.local` (dev) ou configurer sur Netlify (prod).
#  ⚠️ Ne jamais committer `.env.local` ni les vraies valeurs secret.
# =============================================================================

# --- Supabase (obligatoire) -------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # serveur uniquement

# --- Anthropic (obligatoire — agent vocal) ----------------------------------
ANTHROPIC_API_KEY=your-anthropic-key-here

# --- Stripe Connect (obligatoire — paiement marketplace) --------------------
STRIPE_SECRET_KEY=your-stripe-secret-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here
NEXT_PUBLIC_APP_URL=https://les-retraites-travaillent.fr

# --- Resend (recommandé — email transactionnel) -----------------------------
RESEND_API_KEY=your-resend-key-here
RESEND_FROM_EMAIL="Les Retraités Travaillent <hello@les-retraites-travaillent.fr>"

# --- Monitoring (optionnel — peut rester vide en dev) -----------------------
# Sentry — décommenter une fois @sentry/nextjs installé
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_AUTH_TOKEN=xxx

# Plausible Analytics — pas de cookie, pas de bandeau requis
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=les-retraites-travaillent.fr
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js  # défaut

# --- Rate limiting Upstash (optionnel — quand le trafic dépasse 1k req/min) -
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxx
